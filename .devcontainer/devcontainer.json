{
  "name": "kratix-dev",
  "build": { "dockerfile": "Dockerfile" },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "forwardPorts": [10350, 31337, 31340, 31333],
  "postCreateCommand": "go mod download",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "tilt-dev.tiltfile",
        "ms-kubernetes-tools.vscode-kubernetes-tools"
      ]
    }
  }
}
